<form action="/folders/new" method="post">
  <div class="form-group">
    <label for="title">New Folder</label>
    <input 
      type="text" 
      class="title"
      name="title"
      id="title"
      minlength="1"
      maxlength="15"
      placeholder="Title">
  </div>
  <button type="submit">Create</button>
</form>

